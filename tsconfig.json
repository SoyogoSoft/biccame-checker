{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2022",
    "useDefineForClassFields": true,
    "module": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "allowJs": true,
    "composite": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "sourceMap": false,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "#build/ui/*": ["./node_modules/.nuxt-ui/ui/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vite.config.ts",
    "auto-imports.d.ts",
    "components.d.ts"
  ]
}
